{%- comment -%}
  Product structured data (JSON-LD). Richer than the default `structured_data`
  filter: adds brand, per-variant SKU + offers, full image gallery, condition.
  Outputs the JSON object only; the <script type="application/ld+json"> wrapper
  lives in sections/main-product.liquid.
{%- endcomment -%}
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": {{ canonical_url | json }},
  {%- if product.images.size > 0 %}
  "image": [
    {%- for image in product.images -%}
      {{ image | image_url: width: 1200 | prepend: "https:" | json }}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ],
  {%- endif %}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | default: shop.name | json }}
  },
  {%- assign first_variant = product.selected_or_first_available_variant -%}
  {%- if first_variant.sku != blank %}
  "sku": {{ first_variant.sku | json }},
  {%- endif %}
  "offers": [
    {%- for variant in product.variants -%}
    {
      "@type": "Offer",
      {%- if variant.sku != blank %}
      "sku": {{ variant.sku | json }},
      {%- endif %}
      "price": "{{ variant.price | divided_by: 100.0 }}",
      "priceCurrency": {{ shop.currency | json }},
      "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition",
      "url": {{ variant.url | prepend: shop.url | json }}
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}