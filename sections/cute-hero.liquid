<div class="cute-hero">
  <span class="cute-hero__deco cute-hero__deco--1" aria-hidden="true">✿</span>
  <span class="cute-hero__deco cute-hero__deco--2" aria-hidden="true">♡</span>
  <span class="cute-hero__deco cute-hero__deco--3" aria-hidden="true">✦</span>
  <span class="cute-hero__deco cute-hero__deco--4" aria-hidden="true">ʚïɞ</span>
  <div class="page-width cute-hero__inner">
    <div class="cute-hero__text">
      {%- if section.settings.badge != blank -%}
        <span class="cute-badge">✨ {{ section.settings.badge }}</span>
      {%- endif -%}
      <h1 class="cute-hero__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank %} <em class="cute-hero__accent">{{ section.settings.heading_accent }}</em>{% endif %}
        {{ section.settings.heading_post }}
      </h1>
      <p class="cute-hero__sub">{{ section.settings.subheading }}</p>
      <div class="cute-hero__buttons">
        {%- if section.settings.button1_label != blank -%}
          <a class="button cute-hero__cta cute-hero__cta--primary" href="{{ section.settings.button1_link }}">{{ section.settings.button1_label }} →</a>
        {%- endif -%}
        {%- if section.settings.button2_label != blank -%}
          <a class="cute-hero__cta cute-hero__cta--ghost" href="{{ section.settings.button2_link }}">{{ section.settings.button2_label }}</a>
        {%- endif -%}
      </div>
      {%- if section.settings.rating != blank -%}
        <p class="cute-hero__rating"><span class="cute-hero__stars">★★★★★</span> {{ section.settings.rating }} · {{ section.settings.review_count }}</p>
      {%- endif -%}
    </div>
    <div class="cute-hero__media">
      <div class="cute-hero__frame">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1100 | image_tag: loading: 'eager', class: 'cute-hero__img' }}
        {%- elsif section.settings.hero_product != blank -%}
          <a class="cute-hero__product-card" href="{{ section.settings.hero_product.url }}">
            <div class="cute-hero__product-media">
              {{ section.settings.hero_product.featured_image | image_url: width: 800 | image_tag: loading: 'eager', class: 'cute-hero__img' }}
            </div>
            <div class="cute-hero__product-info">
              <span class="cute-hero__product-title">{{ section.settings.hero_product.title }}</span>
              <span class="cute-hero__product-price">{% if section.settings.hero_product.price_varies %}From {% endif %}{{ section.settings.hero_product.price | money }}</span>
              <span class="cute-hero__product-cta">Shop now →</span>
            </div>
          </a>
        {%- else -%}
          <div class="cute-hero__blob" aria-hidden="true">
            <span class="cute-hero__blob-main">🧸</span>
            <span class="cute-hero__blob-deco d1">🎀</span>
            <span class="cute-hero__blob-deco d2">💗</span>
            <span class="cute-hero__blob-deco d3">🌸</span>
            <span class="cute-hero__blob-deco d4">⭐</span>
            <span class="cute-hero__blob-deco d5">🫧</span>
            <span class="cute-hero__blob-deco d6">🩷</span>
          </div>
        {%- endif -%}
        {%- if section.settings.badge1 != blank -%}
          <span class="cute-hero__pill cute-hero__pill--tl">🎁 <strong>{{ section.settings.badge1 }}</strong><br>{{ section.settings.badge1_sub }}</span>
        {%- endif -%}
        {%- if section.settings.badge2 != blank -%}
          <span class="cute-hero__pill cute-hero__pill--br">♥ <strong>{{ section.settings.badge2 }}</strong><br>{{ section.settings.badge2_sub }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
<style>
  .cute-hero {
    position: relative; overflow: hidden;
    background:
      radial-gradient(130% 130% at 0% 10%, #f6e6ff 0%, transparent 55%),
      radial-gradient(130% 130% at 100% 0%, #ffe1ef 0%, transparent 50%),
      linear-gradient(160deg, #efe4ff 0%, #fbe9f3 45%, #e4eeff 100%);
  }
  .cute-hero__inner { display: flex; gap: 3.5rem; align-items: center; justify-content: center; padding: 4.5rem 0 5rem; flex-wrap: wrap; position: relative; z-index: 2; max-width: 1140px; margin-inline: auto; }
  .cute-hero__text { flex: 0 1 540px; }
  .cute-hero__media { flex: 0 0 360px; }
  .cute-hero__frame { position: relative; max-width: 360px; margin-inline: auto; }
  .cute-hero__img { width: 100%; border-radius: 32px; box-shadow: var(--kawaii-shadow); display: block; }
  .cute-hero__product-card { display: block; width: 100%; max-width: 340px; margin-inline: auto; background: #fff; border-radius: 28px; overflow: hidden; box-shadow: var(--kawaii-shadow); text-decoration: none; transition: transform .2s ease, box-shadow .2s ease; }
  .cute-hero__product-card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(74,44,57,0.18); }
  .cute-hero__product-media { line-height: 0; }
  .cute-hero__product-card .cute-hero__img { width: 100%; height: 340px; object-fit: cover; border-radius: 0; box-shadow: none; display: block; }
  .cute-hero__product-info { padding: 0.85rem 1.1rem 1.15rem; text-align: left; }
  .cute-hero__product-title { display: block; font-weight: 700; color: #4a2c39; font-size: 1.02rem; line-height: 1.3; }
  .cute-hero__product-price { display: block; color: #d6438a; font-weight: 800; margin-top: 0.25rem; font-size: 1.05rem; }
  .cute-hero__product-cta { display: inline-block; margin-top: 0.7rem; font-size: 0.85rem; font-weight: 700; color: #fff; background: #ff7bb0; padding: 0.4rem 0.9rem; border-radius: 999px; }
  .cute-hero__heading { font-size: clamp(2.6rem, 6vw, 4.6rem); line-height: 1.02; margin: 0 0 1.25rem; color: var(--k-ink); }
  .cute-hero__accent { color: var(--k-pink-deep); font-style: italic; }
  .cute-hero__sub { font-size: 1.6rem; line-height: 1.5; max-width: 38ch; color: var(--k-ink); opacity: 0.82; }
  .cute-hero__buttons { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.75rem; align-items: center; }
  .cute-hero__cta { display: inline-flex; align-items: center; padding: 0.9rem 1.9rem; border-radius: 999px; text-decoration: none; font-weight: 700; }
  .cute-hero__cta--ghost { background: #fff; color: var(--k-ink); box-shadow: var(--kawaii-shadow-sm); }
  .cute-hero__rating { margin-top: 1.25rem; font-weight: 600; color: var(--k-ink); }
  .cute-hero__stars { color: var(--k-pink); letter-spacing: 1px; }
  .cute-hero__blob {
    position: relative; width: 100%; aspect-ratio: 4/3; border-radius: 32px; overflow: hidden;
    background: radial-gradient(circle at 50% 42%, #ffe3ef 0%, #f3dcff 60%, #e3e9ff 100%);
    box-shadow: var(--kawaii-shadow); display: grid; place-items: center;
  }
  .cute-hero__blob-main { font-size: clamp(7rem, 18vw, 14rem); filter: drop-shadow(0 10px 18px rgba(74,44,57,0.18)); }
  .cute-hero__blob-deco { position: absolute; font-size: 2rem; opacity: 0.9; animation: kawaii-bob 5s ease-in-out infinite; }
  .cute-hero__blob-deco.d1 { top: 12%; left: 14%; font-size: 2.6rem; }
  .cute-hero__blob-deco.d2 { top: 18%; right: 16%; animation-delay: 0.5s; }
  .cute-hero__blob-deco.d3 { bottom: 16%; left: 12%; font-size: 2.3rem; animation-delay: 1s; }
  .cute-hero__blob-deco.d4 { top: 40%; right: 10%; font-size: 1.6rem; animation-delay: 0.7s; }
  .cute-hero__blob-deco.d5 { bottom: 22%; right: 20%; font-size: 1.8rem; animation-delay: 1.3s; }
  .cute-hero__blob-deco.d6 { top: 48%; left: 9%; font-size: 1.6rem; animation-delay: 0.3s; }
  .cute-hero__pill {
    position: absolute; background: #fff; border-radius: 20px; padding: 1rem 1.4rem;
    font-size: 1.15rem; line-height: 1.35; color: var(--k-ink); box-shadow: var(--kawaii-shadow);
  }
  .cute-hero__pill strong { color: var(--k-pink-deep); font-size: 1.3rem; }
  .cute-hero__pill--tl { top: 1.2rem; left: -0.8rem; }
  .cute-hero__pill--br { top: 1.1rem; right: -0.6rem; }
  @media (max-width: 749px) {
    .cute-hero__inner { gap: 2rem; padding: 2.5rem 0 3rem; }
    .cute-hero__text { flex: 1 1 100%; }
    .cute-hero__media { flex: 1 1 100%; width: 100%; }
    .cute-hero__frame { max-width: 340px; }
    .cute-hero__product-card { max-width: 340px; }
  }
  .cute-hero__deco { position: absolute; z-index: 1; opacity: 0.5; color: #ff9ec7; pointer-events: none; animation: kawaii-bob 5s ease-in-out infinite; }
  .cute-hero__deco--1 { top: 14%; left: 5%; font-size: 2rem; }
  .cute-hero__deco--2 { top: 24%; right: 42%; font-size: 2.4rem; animation-delay: 0.6s; }
  .cute-hero__deco--3 { bottom: 16%; left: 9%; font-size: 1.8rem; animation-delay: 1.2s; }
  .cute-hero__deco--4 { top: 66%; right: 3%; font-size: 1.6rem; animation-delay: 0.9s; }
  @keyframes kawaii-bob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
  @media (prefers-reduced-motion: reduce) { .cute-hero__deco { animation: none; } }
</style>
{% schema %}
{
  "name": "Cute hero",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "New Spring Drop" },
    { "type": "text", "id": "heading", "label": "Heading start", "default": "Only the" },
    { "type": "text", "id": "heading_accent", "label": "Accent word (pink italic)", "default": "cutest" },
    { "type": "text", "id": "heading_post", "label": "Heading end", "default": "things, ever." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Hand-picked plushies, accessories, and little daily delights — packed with love and a free sticker in every box." },
    { "type": "image_picker", "id": "image", "label": "Hero image (a cute graphic shows if empty)" },
    { "type": "product", "id": "hero_product", "label": "Hero product (shown if no hero image is set)" },
    { "type": "text", "id": "button1_label", "label": "Button 1 label", "default": "Shop the drop" },
    { "type": "url", "id": "button1_link", "label": "Button 1 link" },
    { "type": "text", "id": "button2_label", "label": "Button 2 label", "default": "Lookbook" },
    { "type": "url", "id": "button2_link", "label": "Button 2 link" },
    { "type": "text", "id": "rating", "label": "Rating", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "12,400+ happy bestie reviews" },
    { "type": "text", "id": "badge1", "label": "Image badge 1", "default": "Free gift" },
    { "type": "text", "id": "badge1_sub", "label": "Image badge 1 subtext", "default": "over $50" },
    { "type": "text", "id": "badge2", "label": "Image badge 2", "default": "Loved by" },
    { "type": "text", "id": "badge2_sub", "label": "Image badge 2 subtext", "default": "12k besties" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [{ "name": "Cute hero" }]
}
{% endschema %}
