{% comment %}
  Sections: Collection Grid
  Displays products from a collection in a grid layout.
{% endcomment %}
<section class="collection-grid-section">
  <div class="collection-grid-container">
    {% if section.settings.show_title %}
      <h2 class="collection-title">{{ section.settings.collection_title }}</h2>
    {% endif %}
    <div class="product-grid">
      {% assign products_to_display = collections[section.settings.collection_handle].products %}
      {% if section.settings.limit > 0 %}
        {% assign products_to_display = products_to_display | slice: 0, section.settings.limit %}
      {% endif %}

      {% for product in products_to_display %}
        <div class="product-item">
          <a href="{{ product.url }}">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 400 | image_tag: alt: product.featured_image.alt, class: 'product-image' }}
            {% endif %}
          </a>
          <div class="product-info">
            <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
            {% if section.settings.show_price %}
              <span class="product-price">{{ product.price | money_with_currency }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.show_view_all %}
      <div class="collection-view-all">
        <a href="{{ collections[section.settings.collection_handle].url }}" class="button">View All</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "text",
      "id": "collection_title",
      "label": "Collection Title",
      "default": "Our Products"
    },
    {
      "type": "collection",
      "id": "collection_handle",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 1,
      "max": 24,
      "step": 1,
      "unit": "items",
      "label": "Number of products to show",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "settings": {
        "collection_handle": "all",
        "limit": 12,
        "show_price": true,
        "show_view_all": true
      }
    }
  ]
}
{% endschema %}

{% stylesheet %}
.collection-grid-section {
  padding: 2rem 1rem;
  font-family: var(--main-font);
}

.collection-grid-container {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}

.collection-title {
  font-size: 2rem;
  margin-bottom: 1.5rem;
  color: var(--primary-color);
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.product-item {
  text-align: center;
}

.product-image {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.product-info h3 {
  font-size: 1.1rem;
  margin-top: 0.8rem;
  margin-bottom: 0.3rem;
}

.product-info a {
  text-decoration: none;
  color: #333;
}

.product-price {
  font-weight: bold;
  color: var(--primary-color);
}

.collection-view-all {
  margin-top: 1rem;
}
.collection-view-all .button {
  display: inline-block;
  padding: 0.8rem 1.5rem;
  background-color: var(--primary-color);
  color: #fff;
  text-decoration: none;
  border-radius: 5px;
  font-weight: bold;
  transition: background-color 0.3s ease;
}
.collection-view-all .button:hover {
  background-color: #e0a0b0; /* Darker shade of primary */
}
{% endstylesheet %}