<div class="color-{{ section.settings.color_scheme | default: 'scheme-1' }} gradient">
  <div class="page-width cute-collections">
    <div class="cute-section-head">
      <div>
        {%- if section.settings.badge != blank -%}<span class="cute-badge">✦ {{ section.settings.badge }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="cute-section-title">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.view_all_link != blank -%}
        <a class="cute-viewall" href="{{ section.settings.view_all_link }}">View all →</a>
      {%- endif -%}
    </div>
    <div class="cute-collections__grid">
      {%- for block in section.blocks -%}
        {%- assign coll = block.settings.collection -%}
        {%- if coll != blank -%}
          <a class="cute-collections__card" href="{{ coll.url }}" {{ block.shopify_attributes }}>
            {%- if coll.featured_image -%}
              {{ coll.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'cute-collections__img' }}
            {%- else -%}
              <span class="cute-collections__img cute-collections__img--ph"></span>
            {%- endif -%}
            <span class="cute-collections__overlay"></span>
            <span class="cute-collections__meta">
              <span class="cute-collections__name">{{ block.settings.custom_title | default: coll.title }}</span>
              <span class="cute-collections__count">{{ coll.products_count }} pieces</span>
            </span>
            <span class="cute-collections__arrow" aria-hidden="true">→</span>
          </a>
        {%- elsif request.design_mode -%}
          <div class="cute-collections__card" {{ block.shopify_attributes }}>
            <span class="cute-collections__img cute-collections__img--ph"></span>
            <span class="cute-collections__meta"><span class="cute-collections__name">Pick a collection</span></span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>
<style>
  .cute-collections { padding: 4.5rem 0; }
  .cute-collections__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 280px)); justify-content: center; gap: 1.5rem; }
  .cute-collections__card {
    position: relative; display: block; border-radius: 28px; overflow: hidden;
    aspect-ratio: 3/4; text-decoration: none; box-shadow: var(--kawaii-shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .cute-collections__card:hover { transform: translateY(-6px); box-shadow: var(--kawaii-shadow); }
  .cute-collections__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .cute-collections__img--ph { background: linear-gradient(150deg, var(--k-blush), var(--k-lilac)); }
  .cute-collections__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 45%, rgba(58,34,48,0.55) 100%); }
  .cute-collections__meta { position: absolute; left: 1.4rem; bottom: 1.4rem; right: 4.5rem; display: flex; flex-direction: column; gap: 0.15rem; }
  .cute-collections__name { color: #fff; font-size: 1.6rem; font-weight: 600; }
  .cute-collections__count { color: rgba(255,255,255,0.85); font-size: 0.9rem; font-weight: 600; }
  .cute-collections__arrow {
    position: absolute; right: 1.2rem; bottom: 1.2rem; width: 44px; height: 44px;
    background: #fff; color: var(--k-ink); border-radius: 50%; display: grid; place-items: center;
    font-size: 1.2rem; box-shadow: var(--kawaii-shadow-sm); transition: transform 0.2s ease;
  }
  .cute-collections__card:hover .cute-collections__arrow { transform: translateX(3px); }
</style>
{% schema %}
{
  "name": "Cute collections",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick your flavor of cute" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    { "type": "collection_card", "name": "Collection", "settings": [
      { "type": "collection", "id": "collection", "label": "Collection" },
      { "type": "text", "id": "custom_title", "label": "Custom title (optional)" }
    ]}
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Cute collections", "blocks": [
    { "type": "collection_card" }, { "type": "collection_card" }, { "type": "collection_card" }
  ]}]
}
{% endschema %}
