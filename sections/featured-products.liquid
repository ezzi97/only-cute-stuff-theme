<section class="featured-products">
  <div class="featured-products-container">
    <h2>{{ block.settings.featured_products_title }}</h2>
    <div class="product-grid">
      {% for product in collections[block.settings.featured_collection].products %}
        {% if forloop.index <= block.settings.products_to_show %}
          <div class="product-item">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 400 | image_tag: alt: product.featured_image.alt | class: 'product-image' }}
              {% endif %}
            </a>
            <div class="product-info">
              <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
              {% if block.settings.show_price %}
                <span class="product-price">{{ product.price | money_with_currency }}</span>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "featured_products_title",
      "label": "Section Title",
      "default": "Featured Picks"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "products",
      "label": "Number of products to show",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "settings": {
        "featured_collection": "all",
        "products_to_show": 4,
        "show_price": true
      }
    }
  ]
}
{% endschema %}